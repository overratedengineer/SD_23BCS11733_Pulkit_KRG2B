        <mxCell id="footer-text" value="&lt;font style=&quot;font-size:12px;color:#a7a7c4;&quot;&gt;PasteCTL System Design — &lt;b style=&quot;color:#e94560;&quot;&gt;paste.sumedh.app&lt;/b&gt; — Built with Go + Next.js + PostgreSQL — Made with ❤️ by Sumedh&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
