        <mxCell id="test-unit" value="&lt;font style=&quot;font-size:13px;font-weight:bold;color:#53d769;&quot;&gt;✅ Unit Tests&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;tests/http_test/ — Mocked services&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#a7a7c4;&quot;&gt;Handler validation, error paths&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#53d769;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="3070" y="1120" width="390" height="70" as="geometry" />
        </mxCell>

        <mxCell id="test-integration" value="&lt;font style=&quot;font-size:13px;font-weight:bold;color:#00d2ff;&quot;&gt;🧪 Integration Tests&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;tests/db_test/ — Testcontainers (PostgreSQL)&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;tests/service_test/ — Full service flow&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#a7a7c4;&quot;&gt;Real DB, end-to-end queries&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#00d2ff;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="3070" y="1210" width="390" height="80" as="geometry" />
        </mxCell>

        <mxCell id="test-cmd" value="&lt;div style=&quot;text-align:left;padding:8px;font-family:monospace;font-size:11px;color:#e0e0e0;line-height:1.7;&quot;&gt;&#xa;&lt;b style=&quot;color:#ffcc00;&quot;&gt;Commands:&lt;/b&gt;&#xa;&lt;br&gt;&lt;span style=&quot;color:#53d769;&quot;&gt;$&lt;/span&gt; go test ./...&#xa;&lt;br&gt;&lt;span style=&quot;color:#53d769;&quot;&gt;$&lt;/span&gt; go test -cover ./...&#xa;&lt;br&gt;&lt;span style=&quot;color:#53d769;&quot;&gt;$&lt;/span&gt; go test ./internal/db/...&#xa;&lt;br&gt;&lt;span style=&quot;color:#53d769;&quot;&gt;$&lt;/span&gt; go test ./internal/http/...&#xa;&lt;br&gt;&lt;span style=&quot;color:#53d769;&quot;&gt;$&lt;/span&gt; go test ./internal/paste/...&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="3070" y="1310" width="390" height="110" as="geometry" />
        </mxCell>

        <!-- ====== DATA FLOW LEGEND ====== -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="3560" y="1100" width="800" height="340" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#e94560;&quot;&gt;🔄 DATA FLOW — CREATE PASTE&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="3560" y="1070" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="flow-content" value="&lt;div style=&quot;text-align:left;padding:15px;font-size:12px;color:#e0e0e0;line-height:2.2;&quot;&gt;&#xa;&lt;b style=&quot;color:#00d2ff;&quot;&gt;1.&lt;/b&gt; User types code in &lt;b&gt;CodeEditor&lt;/b&gt; component → selects language &amp;amp; expiry&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;2.&lt;/b&gt; Frontend sends &lt;b style=&quot;color:#53d769;&quot;&gt;POST /api/pastes&lt;/b&gt; with { content, language, expire }&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;3.&lt;/b&gt; &lt;b style=&quot;color:#ff6b6b;&quot;&gt;Rate Limiter MW&lt;/b&gt; checks IP against sliding window (60/min)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;4.&lt;/b&gt; &lt;b&gt;CreatePasteHandler&lt;/b&gt; validates &amp;amp; parses expiry → calls Service&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;5.&lt;/b&gt; &lt;b&gt;PasteService.CreatePaste&lt;/b&gt; generates 5-char ID (retry up to 5x on collision)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;6.&lt;/b&gt; &lt;b&gt;Repository.CreatePaste&lt;/b&gt; executes INSERT via pgx connection pool&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;7.&lt;/b&gt; Response returned → frontend redirects to &lt;b&gt;/paste/:id&lt;/b&gt;&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;8.&lt;/b&gt; &lt;b style=&quot;color:#e94560;&quot;&gt;WebSocket&lt;/b&gt; connection opens for live collaborative editing&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;9.&lt;/b&gt; Edits broadcast to all peers &amp;amp; debounced auto-save to backend (1s)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;10.&lt;/b&gt; &lt;b style=&quot;color:#ff9f43;&quot;&gt;Scheduler goroutine&lt;/b&gt; runs every 2h → purges expired pastes&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="3570" y="1110" width="780" height="320" as="geometry" />
        </mxCell>

        <!-- ====== PROJECT STRUCTURE ====== -->
        <mxCell id="structure-label" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#e94560;&quot;&gt;📁 PROJECT STRUCTURE&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1470" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="structure-box" value="&lt;div style=&quot;text-align:left;padding:15px;font-family:monospace;font-size:11px;color:#e0e0e0;line-height:1.7;&quot;&gt;&#xa;&lt;b style=&quot;color:#00d2ff;&quot;&gt;pasteCTL/&lt;/b&gt;&#xa;&lt;br&gt;├── &lt;b style=&quot;color:#ff9f43;&quot;&gt;backend/&lt;/b&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── &lt;b style=&quot;color:#ffcc00;&quot;&gt;cmd/&lt;/b&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; ├── main.go &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Entry point, router setup&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; └── scheduledJob/ &amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Background cleanup goroutine&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── &lt;b style=&quot;color:#ffcc00;&quot;&gt;internal/&lt;/b&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; ├── db/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# DB init, connection pool, Repository&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; ├── http/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Gin HTTP handlers&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; ├── paste/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Business logic / PasteService&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; ├── ws/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# WebSocket handler (Gorilla)&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; │ &amp;nbsp; └── middleware/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Rate limiter middleware&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── &lt;b style=&quot;color:#ffcc00;&quot;&gt;pkg/&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Shared utilities (ID generator)&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── &lt;b style=&quot;color:#ffcc00;&quot;&gt;migrations/&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# SQL migration files&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── &lt;b style=&quot;color:#ffcc00;&quot;&gt;tests/&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# db_test, http_test, service_test&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; └── Dockerfile&#xa;&lt;br&gt;├── &lt;b style=&quot;color:#ff9f43;&quot;&gt;frontend/&lt;/b&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── app/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# Next.js pages (page.tsx, paste/[id])&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; ├── components/ &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;# CodeEditor, Header, UI primitives&lt;/span&gt;&#xa;&lt;br&gt;│ &amp;nbsp; └── tailwind.config.ts&#xa;&lt;br&gt;└── README.md&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="2550" y="1500" width="1810" height="250" as="geometry" />
        </mxCell>

        <!-- ====== TECH STACK SUMMARY ====== -->
        <mxCell id="tech-label" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#e94560;&quot;&gt;🛠️ TECH STACK SUMMARY&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="1470" width="300" height="30" as="geometry" />
