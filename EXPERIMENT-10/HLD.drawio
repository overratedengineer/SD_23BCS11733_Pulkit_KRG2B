<mxfile host="app.diagrams.net" agent="Antigravity" version="26.0">
  <diagram id="pastectl-system-design" name="PasteCTL System Design">
    <mxGraphModel dx="2800" dy="2400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="4400" pageHeight="3400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============================================== -->
        <!-- MAIN TITLE BANNER                              -->
        <!-- ============================================== -->
        <mxCell id="title-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="4360" height="90" as="geometry" />
        </mxCell>
        <mxCell id="title-text" value="&lt;font style=&quot;font-size:32px;font-weight:bold;color:#e94560;&quot;&gt;📋 PasteCTL — System Design&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:14px;color:#a7a7c4;&quot;&gt;A modern code snippet sharing platform with syntax highlighting, live collaborative editing, and expirable pastes&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="4360" height="90" as="geometry" />
        </mxCell>

        <!-- ============================================== -->
        <!-- SECTION 1: AIM / DESCRIPTION                   -->
        <!-- ============================================== -->
        <mxCell id="aim-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#16213e;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aim-header-text" value="&lt;font style=&quot;font-size:18px;font-weight:bold;color:#e94560;&quot;&gt;🎯 AIM / DESCRIPTION&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="140" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="aim-body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#1a1a2e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="190" width="1400" height="260" as="geometry" />
        </mxCell>
        <mxCell id="aim-content" value="&lt;div style=&quot;text-align:left;padding:15px;color:#e0e0e0;font-size:13px;line-height:1.8;&quot;&gt;&#xa;&lt;b style=&quot;color:#00d2ff;font-size:14px;&quot;&gt;PasteCTL&lt;/b&gt; is a lightweight, modern pastebin alternative designed for developers.&#xa;&lt;br&gt;&lt;br&gt;&#xa;&lt;b style=&quot;color:#e94560;&quot;&gt;Problem:&lt;/b&gt; Developers need a fast, reliable way to share code snippets with proper syntax&#xa;highlighting, configurable expiry, and real-time collaboration — without the bloat of full&#xa;IDE sharing tools.&#xa;&lt;br&gt;&lt;br&gt;&#xa;&lt;b style=&quot;color:#e94560;&quot;&gt;Solution:&lt;/b&gt; A full-stack platform with:&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;Next.js frontend&lt;/b&gt; deployed on AWS Amplify for a fast, responsive UI&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;Go (Gin) backend&lt;/b&gt; deployed on AWS EC2 for high-performance API serving&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;PostgreSQL&lt;/b&gt; for persistent paste storage with connection pooling (pgx)&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;WebSocket (Gorilla)&lt;/b&gt; for real-time collaborative editing&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;CLI tool (pasteCTL)&lt;/b&gt; for terminal-native workflows&#xa;&lt;br&gt;• &lt;b style=&quot;color:#53d769;&quot;&gt;Sliding window rate limiter&lt;/b&gt; for API abuse protection&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="1380" height="240" as="geometry" />
        </mxCell>

        <!-- ============================================== -->
        <!-- SECTION 2: FUNCTIONAL REQUIREMENTS             -->
        <!-- ============================================== -->
        <mxCell id="fr-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#16213e;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1460" y="140" width="1420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fr-header-text" value="&lt;font style=&quot;font-size:18px;font-weight:bold;color:#e94560;&quot;&gt;✅ FUNCTIONAL REQUIREMENTS&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1460" y="140" width="1420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="fr-body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#1a1a2e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1460" y="190" width="1420" height="260" as="geometry" />
        </mxCell>
        <mxCell id="fr-content" value="&lt;div style=&quot;text-align:left;padding:15px;color:#e0e0e0;font-size:13px;line-height:1.9;&quot;&gt;&#xa;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-1&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;create a new paste&lt;/b&gt; with content, language, and optional expiry (1h/24h/7d/never)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-2&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;retrieve a paste&lt;/b&gt; by its unique short ID&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-3&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;retrieve raw content&lt;/b&gt; of a paste (for CLI / curl usage)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-4&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;update paste content&lt;/b&gt; in real-time (live collaborative editing via WebSocket)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-5&lt;/b&gt; &amp;nbsp; System &lt;b&gt;tracks view counts&lt;/b&gt; for each paste (incremented on page load)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-6&lt;/b&gt; &amp;nbsp; System &lt;b&gt;auto-deletes expired pastes&lt;/b&gt; via a background scheduled job (every 2h)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-7&lt;/b&gt; &amp;nbsp; System supports &lt;b&gt;syntax highlighting&lt;/b&gt; for 8+ languages (JS, Python, Go, Java, C, C++, SQL, Plain)&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-8&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;copy paste content&lt;/b&gt; to clipboard and open &lt;b&gt;raw view&lt;/b&gt; in a new tab&#xa;&lt;br&gt;&lt;b style=&quot;color:#00d2ff;&quot;&gt;FR-9&lt;/b&gt; &amp;nbsp; Users can &lt;b&gt;create/share pastes from the CLI&lt;/b&gt; (pasteCTL CLI tool)&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1470" y="200" width="1400" height="240" as="geometry" />
        </mxCell>

        <!-- ============================================== -->
        <!-- SECTION 3: NON-FUNCTIONAL REQUIREMENTS         -->
        <!-- ============================================== -->
        <mxCell id="nfr-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#16213e;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2920" y="140" width="1460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nfr-header-text" value="&lt;font style=&quot;font-size:18px;font-weight:bold;color:#e94560;&quot;&gt;⚡ NON-FUNCTIONAL REQUIREMENTS&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="2920" y="140" width="1460" height="40" as="geometry" />
        </mxCell>
        <mxCell id="nfr-body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#1a1a2e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="2920" y="190" width="1460" height="260" as="geometry" />
        </mxCell>
        <mxCell id="nfr-content" value="&lt;div style=&quot;text-align:left;padding:15px;color:#e0e0e0;font-size:13px;line-height:1.9;&quot;&gt;&#xa;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-1  Availability:&lt;/b&gt; &amp;nbsp; System should have &lt;b&gt;99.9% uptime&lt;/b&gt; — deployed on AWS EC2 + Amplify&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-2  Latency:&lt;/b&gt; &amp;nbsp; API response time &lt;b&gt;&amp;lt; 100ms&lt;/b&gt; (p95) for paste CRUD operations&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-3  Scalability:&lt;/b&gt; &amp;nbsp; Connection pooling via pgx; stateless API is horizontally scalable&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-4  Security:&lt;/b&gt; &amp;nbsp; CORS whitelist, parameterized SQL queries, rate limiting (60 req/min/IP)&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-5  Durability:&lt;/b&gt; &amp;nbsp; PostgreSQL with data persistence; auto-cleanup of expired pastes&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-6  Real-Time:&lt;/b&gt; &amp;nbsp; WebSocket-based live editing with &lt;b&gt;&amp;lt; 50ms&lt;/b&gt; propagation delay&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-7  Testability:&lt;/b&gt; &amp;nbsp; Testcontainers for integration tests; interface-based DI&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-8  Maintainability:&lt;/b&gt; &amp;nbsp; Clean MVC layered architecture (Handler → Service → Repository)&#xa;&lt;br&gt;&lt;b style=&quot;color:#ff6b6b;&quot;&gt;NFR-9  Fault Tolerance:&lt;/b&gt; &amp;nbsp; Rate limiter fails open; WebSocket auto-reconnects after 2s&#xa;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="2930" y="200" width="1440" height="240" as="geometry" />
        </mxCell>

        <!-- ============================================== -->
        <!-- SECTION 4: CORE ENTITIES / DB SCHEMA           -->
        <!-- ============================================== -->
        <mxCell id="entity-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#16213e;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="entity-header-text" value="&lt;font style=&quot;font-size:18px;font-weight:bold;color:#e94560;&quot;&gt;🗄️ CORE ENTITIES / DATABASE SCHEMA&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="1400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="entity-body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#1a1a2e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="540" width="1400" height="420" as="geometry" />
        </mxCell>

        <!-- Paste Table -->
        <mxCell id="paste-table-header" value="&lt;font style=&quot;font-size:15px;font-weight:bold;color:#00d2ff;&quot;&gt;📄 pastes&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#a7a7c4;&quot;&gt;Primary table — stores all paste data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="570" width="620" height="50" as="geometry" />
        </mxCell>
        <mxCell id="paste-table-body" value="&lt;div style=&quot;text-align:left;padding:10px;font-family:monospace;font-size:12px;line-height:2.2;color:#e0e0e0;&quot;&gt;&#xa;&lt;span style=&quot;color:#ffcc00;&quot;&gt;PK&lt;/span&gt; &amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;id&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; TEXT &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; PRIMARY KEY (5-char alphanumeric, collision-safe)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;content&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; TEXT &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; NOT NULL — the paste body&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;language&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; TEXT &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; NOT NULL — programming language tag&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;created_at&lt;/b&gt; &amp;nbsp;&amp;nbsp; TIMESTAMP &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; NOT NULL DEFAULT NOW()&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;expire_at&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp; TIMESTAMP &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; NULLABLE — NULL means "never expires"&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;b style=&quot;color:#53d769;&quot;&gt;views&lt;/b&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; INT &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; NOT NULL DEFAULT 0&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="630" width="620" height="200" as="geometry" />
        </mxCell>

        <!-- Go Struct -->
        <mxCell id="go-struct-header" value="&lt;font style=&quot;font-size:15px;font-weight:bold;color:#00d2ff;&quot;&gt;🔧 Go Struct: db.Paste&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#a7a7c4;&quot;&gt;internal/db/repo.go&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="720" y="570" width="660" height="50" as="geometry" />
        </mxCell>
        <mxCell id="go-struct-body" value="&lt;div style=&quot;text-align:left;padding:10px;font-family:monospace;font-size:12px;line-height:2.0;color:#e0e0e0;&quot;&gt;&#xa;&lt;span style=&quot;color:#ff79c6;&quot;&gt;type&lt;/span&gt; &lt;b style=&quot;color:#8be9fd;&quot;&gt;Paste&lt;/b&gt; &lt;span style=&quot;color:#ff79c6;&quot;&gt;struct&lt;/span&gt; {&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; ID &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#53d769;&quot;&gt;string&lt;/span&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;id&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; Content &amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#53d769;&quot;&gt;string&lt;/span&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;content&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; Language &amp;nbsp; &lt;span style=&quot;color:#53d769;&quot;&gt;string&lt;/span&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;language&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; CreatedAt &lt;span style=&quot;color:#53d769;&quot;&gt;time.Time&lt;/span&gt; &amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;created_at&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; ExpireAt &amp;nbsp; &lt;span style=&quot;color:#53d769;&quot;&gt;*time.Time&lt;/span&gt; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;expire_at,omitempty&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; Views &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#53d769;&quot;&gt;int&lt;/span&gt; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;span style=&quot;color:#a7a7c4;&quot;&gt;`json:&amp;quot;views&amp;quot;`&lt;/span&gt;&#xa;&lt;br&gt;}&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="720" y="630" width="660" height="200" as="geometry" />
        </mxCell>

        <!-- Interfaces -->
        <mxCell id="interfaces-header" value="&lt;font style=&quot;font-size:15px;font-weight:bold;color:#00d2ff;&quot;&gt;🔌 Interfaces (Dependency Injection)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="1320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="interfaces-body" value="&lt;div style=&quot;text-align:left;padding:12px;font-family:monospace;font-size:12px;line-height:1.9;color:#e0e0e0;&quot;&gt;&#xa;&lt;b style=&quot;color:#ffcc00;&quot;&gt;Repository Interface&lt;/b&gt; (internal/db/repo.go)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; CreatePaste(p *Paste) error&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; UpdatePaste(p *Paste) error&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; UpdateViews(p *Paste, count int) error&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; GetPaste(id string) (*Paste, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; DeleteExpired() error&#xa;&lt;br&gt;&lt;br&gt;&#xa;&lt;b style=&quot;color:#ffcc00;&quot;&gt;PasteService Interface&lt;/b&gt; (internal/paste/pasteService.go)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; CreatePaste(content, lang string, expireMinutes int) (*Paste, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; GetPaste(id string) (*Paste, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; GetContent(id string) (string, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; UpdatePaste(id, content, lang string) (*Paste, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; UpdateViews(id string, count int) (*Paste, error)&#xa;&lt;br&gt;&amp;nbsp;&amp;nbsp; DeleteExpiredPastes() error&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="900" width="1320" height="50" as="geometry" />
        </mxCell>

        <!-- ============================================== -->
        <!-- SECTION 5: API DESIGN                          -->
        <!-- ============================================== -->
        <mxCell id="api-header" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#16213e;arcSize=12;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1460" y="490" width="2920" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api-header-text" value="&lt;font style=&quot;font-size:18px;font-weight:bold;color:#e94560;&quot;&gt;🌐 API DESIGN&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1460" y="490" width="2920" height="40" as="geometry" />
        </mxCell>
        <mxCell id="api-body" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#1a1a2e;arcSize=8;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1460" y="540" width="2920" height="420" as="geometry" />
        </mxCell>

        <!-- API Endpoint 1: POST /api/pastes -->
        <mxCell id="api1-method" value="&lt;font style=&quot;font-size:12px;font-weight:bold;color:#fff;&quot;&gt;POST&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#53d769;strokeColor=none;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="1490" y="560" width="60" height="28" as="geometry" />
        </mxCell>
        <mxCell id="api1-path" value="&lt;font style=&quot;font-size:13px;font-weight:bold;color:#e0e0e0;font-family:monospace;&quot;&gt;/api/pastes&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1560" y="560" width="200" height="28" as="geometry" />
        </mxCell>
        <mxCell id="api1-desc" value="&lt;font style=&quot;font-size:11px;color:#a7a7c4;&quot;&gt;Create a new paste&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1780" y="560" width="200" height="28" as="geometry" />
        </mxCell>
        <mxCell id="api1-req" value="&lt;div style=&quot;text-align:left;font-family:monospace;font-size:11px;color:#e0e0e0;line-height:1.6;padding:5px;&quot;&gt;&#xa;&lt;b style=&quot;color:#ffcc00;&quot;&gt;Request Body:&lt;/b&gt;&#xa;&lt;br&gt;{ content: string,&#xa;&lt;br&gt;&amp;nbsp; language: string,&#xa;&lt;br&gt;&amp;nbsp; expire: &amp;quot;1h&amp;quot;|&amp;quot;24h&amp;quot;|&amp;quot;7d&amp;quot;|&amp;quot;never&amp;quot; }&#xa;&lt;br&gt;&lt;b style=&quot;color:#53d769;&quot;&gt;Response 200:&lt;/b&gt; Paste object&#xa;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#0f3460;arcSize=8;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1490" y="595" width="320" height="120" as="geometry" />
        </mxCell>

        <!-- API Endpoint 2: GET /api/pastes/:id -->
