        <mxCell id="tech-fe" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#00d2ff;&quot;&gt;Frontend&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;Next.js · React · TypeScript&lt;br&gt;Tailwind CSS · Lucide React&lt;br&gt;Sonner (toast) · date-fns&lt;br&gt;ShadCN UI Components&lt;br&gt;AWS Amplify (hosting)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#00d2ff;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="1510" width="220" height="180" as="geometry" />
        </mxCell>

        <mxCell id="tech-be" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#53d769;&quot;&gt;Backend&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;Go 1.24 · Gin Framework&lt;br&gt;pgx/v5 (PostgreSQL driver)&lt;br&gt;Gorilla WebSocket&lt;br&gt;godotenv · rate-limiter-go&lt;br&gt;AWS EC2 · Docker&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#53d769;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="1510" width="220" height="180" as="geometry" />
        </mxCell>

        <mxCell id="tech-db" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#ffcc00;&quot;&gt;Database&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;PostgreSQL&lt;br&gt;pgxpool (connection pool)&lt;br&gt;SQL migrations&lt;br&gt;Parameterized queries&lt;br&gt;Testcontainers (testing)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#ffcc00;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="540" y="1510" width="220" height="180" as="geometry" />
        </mxCell>

        <mxCell id="tech-infra" value="&lt;font style=&quot;font-size:14px;font-weight:bold;color:#e94560;&quot;&gt;Security&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;color:#e0e0e0;&quot;&gt;CORS whitelist&lt;br&gt;Rate limiting (sliding window)&lt;br&gt;Parameterized SQL queries&lt;br&gt;Auto-expiry of content&lt;br&gt;Input validation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d3436;strokeColor=#e94560;arcSize=12;shadow=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="780" y="1510" width="220" height="180" as="geometry" />
        </mxCell>

